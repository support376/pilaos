# === Public (브라우저 노출) ===

# 사이트 절대 URL (OG/메타 baseUrl). 미설정 시 https://pilaos.vercel.app 가정.
NEXT_PUBLIC_SITE_URL=https://pilaos.vercel.app

# 스튜디오 상세의 1km 반경 지도(StudioMap)에 사용. Kakao Developers > 앱 > 플랫폼 > 웹 > 사이트 도메인 등록 후 JavaScript 키 사용.
NEXT_PUBLIC_KAKAO_JS_KEY=

# === Server-only (Vercel에서 노출 환경변수에 추가하지 말 것) ===

# Waitlist(오너 인증 신청) 저장 — Supabase REST. 미설정 시 콘솔 로그 폴백.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
